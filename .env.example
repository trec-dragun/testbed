# For Claude Code through OpenRouter generation.
OPENROUTER_API_KEY=sk-or-...

# Optional AutoJudge override. The OpenRouter OpenAI-compatible base URL uses /api/v1.
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_MODEL=openai/gpt-oss-120b

# Optional Claude Code generation limits.
MAX_BUDGET_USD=5.00
CLAUDE_PERMISSION_MODE=auto
