# For Codex/OpenRouter generation and OpenRouter AutoJudge.
OPENROUTER_API_KEY=sk-or-...

# Optional AutoJudge override. The OpenRouter OpenAI-compatible base URL uses /api/v1.
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_MODEL=openai/gpt-oss-120b

# Optional Claude Code generation limits.
MAX_BUDGET_USD=5.00
CLAUDE_PERMISSION_MODE=acceptEdits
CLAUDE_TOOLS=WebFetch,WebSearch,Read,Write

# Optional Codex generation controls.
CODEX_REASONING_EFFORT=high
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX=workspace-write
CODEX_WEB_SEARCH=1

# Optional OpenRouter server-tool controls for Codex/OpenRouter.
OPENROUTER_WEB_SEARCH=1
OPENROUTER_WEB_FETCH=1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
